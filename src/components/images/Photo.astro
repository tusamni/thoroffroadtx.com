---
// components
import { Picture } from "@astrojs/image/components";

// functions
import { getImage } from "@/functions/Media";

// props
export interface Props {
    src: string;
    widths?: Array<number>;
    sizes?: string;
}
const { src, widths = [400, 800, 1600, 2000], sizes = "100vw", ...attrs } = Astro.props as Props;

const image = await getImage(src);
---

<Picture src={image.src} alt={image.alt} aspectRatio={image.aspectRatio} formats={["webp"]} sizes={sizes} widths={widths} {...attrs} />
