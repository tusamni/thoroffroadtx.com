---
// components
import { Icon } from "astro-icon";
import { getImage } from "@astrojs/image";
import Button from "@/components/buttons/Button";
import Container from "@/components/Container";
import Flyout from "@/components/navigation/menus/Flyout";
import MegaMenu from "@/components/navigation/menus/MegaMenu";

// data
import { business, logos } from "@/data/business";
import { parts, vehicles } from "@/data/menus";

// functions
import { getPublicPath } from "@/functions/Media";

// images
const icon = getPublicPath(
    "/Images/Vehicles/Ford/F-250/2110-2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey/2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey_003.jpg"
);
const thumbnail = await getImage({
    src: icon,
    width: 200,
    height: 200,
});
---

<div class="bg-tan-500 sticky top-0 z-50 shadow-2xl">
    <div class="relative">
        <Container>
            <div class="flex justify-between items-center">
                <div class="flex w-full lg:w-auto justify-between lg:justify-start items-center gap-6 py-6 md:py-0">
                    <!-- logo -->
                    <a href="/" title={business.name_long}>
                        <img src={`${logos.dark}.svg`} alt={business.name_long} class="w-40" />
                    </a>

                    <!-- desktop menu -->
                    <div class="hidden md:flex font-medium">
                        <!-- vehicles -->
                        <MegaMenu name="Vehicles" menu={vehicles} target="vehiclesMega" url="/vehicles" />

                        <!-- parts -->
                        <MegaMenu name="Parts" menu={parts} target="partsMega" url="/parts" />

                        <div class="py-10 px-4 hover:bg-white">Gallery</div>
                        <div class="py-10 px-4 hover:bg-white">Feed</div>
                        <div class="lg:hidden py-10 px-4 hover:bg-white">Contact Us</div>
                    </div>
                </div>

                <div class="md:hidden" x-data={"{ flyout: true }"}>
                    <a x-on:click={"flyout = true"}>
                        <Icon name="bi:list" class="w-8 h-auto" x-show={"!flyout"} />
                        <Icon name="bi:x" class="w-8 h-auto" x-show={"flyout"} />
                    </a>

                    <div x-show={"flyout"}>
                        <Flyout />
                    </div>
                </div>

                <div class="hidden lg:flex gap-4">
                    <Button text="Call Us" url="/contact">
                        <Icon name="bi:telephone" class="w-3 h-auto" />
                    </Button>
                    <Button text="Contact Us" url="/contact" theme="secondary">
                        <Icon name="bi:envelope" class="w-3 h-auto" />
                    </Button>
                </div>
            </div>
        </Container>
    </div>
</div>
