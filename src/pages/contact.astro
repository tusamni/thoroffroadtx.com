---
// layouts
import Layout from "@/layouts/Layout";

// components
import { Icon } from "astro-icon";
import { Image } from "@astrojs/image/components";
import Button from "@/components/buttons/Button";
import Contact from "@/components/Contact";
import Container from "@/components/Container";

// data
import { business, logos } from "@/data/business";

// functions
import { getImage, getPublicPath } from "@/functions/Media";

// page data
const bg = await getImage("vehicles/ford/bronco/2112-2021-ford-bronco-badlands-oxford-white/2021-ford-bronco-badlands-oxford-white_019");
---

<Layout contact={false}>
    <div class="relative py-52">
        <Image src={bg.src} width={2000} aspectRatio={bg.aspectRatio} alt={bg.alt} class="object-cover absolute inset-0 w-full h-full" />
        <div class="absolute top-0 left-0 w-full h-full bg-black opacity-70"></div>

        <Container classes="py-28 !px-16 relative bg-white bg-clip-padding backdrop-filter backdrop-blur-xl bg-opacity-50 rounded-sm shadow-2xl">
            <div class="grid grid-cols-2 gap-12">
                <div class="space-y-6 max-w-md">
                    <h1>Contact Us</h1>
                    <p class="text-neutral-100 text-2xl leading-9">Let's get started creating your purpose built off-road vehicle!</p>
                    <Contact classes="space-y-4 font-light ml-6 text-neutral-200" />
                    <p class="text-neutral-100 text-lg">
                        Give us a call or send us an email when you are ready to schedule your build or just looking for some help in developing a
                        plan and budget for the truck or off-road vehicle of your dreams. The shop is open Monday through Friday from 8am to 5pm.
                    </p>
                </div>

                <form class="flex flex-col gap-6 w-full">
                    <div class="flex flex-col lg:flex-row gap-6">
                        <div class="w-full flex flex-col gap-6">
                            <div class="flex flex-col gap-1">
                                <label for="name" class="text-white text-lg">Name</label>
                                <input
                                    type="text"
                                    name="name"
                                    id="name"
                                    class="font-light text-sm rounded-sm w-full p-3 outline-0 border-0 focus:ring-4 focus:ring-neutral-200"
                                    required
                                />
                            </div>

                            <div class="flex flex-col gap-1">
                                <label for="email" class="text-white text-lg">E-mail</label>
                                <input
                                    type="email"
                                    name="email"
                                    id="email"
                                    class="font-light text-sm rounded-sm w-full p-3 outline-0 border-0 focus:ring-4 focus:ring-neutral-200"
                                    required
                                />
                            </div>

                            <div class="flex flex-col gap-1">
                                <label for="phone" class="text-white text-lg">Phone</label>
                                <input
                                    type="tel"
                                    name="phone"
                                    id="phone"
                                    class="font-light text-sm rounded-sm w-full p-3 outline-0 border-0 focus:ring-4 focus:ring-neutral-200"
                                />
                            </div>

                            <div class="flex flex-col gap-1 h-full">
                                <label for="message" class="text-white text-lg">Message</label>
                                <textarea
                                    name="message"
                                    id="message"
                                    class="font-light text-sm rounded-sm w-full p-3 outline-0 border-0 focus:ring-4 focus:ring-neutral-200 h-32"
                                ></textarea>
                            </div>
                        </div>
                    </div>

                    <Button text="Get Started!" theme="btn-secondary" classes="max-w-fit" type="submit" />
                </form>
            </div>
        </Container>
    </div>

    <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6896.848235522606!2d-98.0203109!3d30.196440400000014!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x8d5bae8937d3b284!2sTHOR%20Off%20Road!5e0!3m2!1sen!2sus!4v1663191464594!5m2!1sen!2sus"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-[700px] border-0"
    >
    </iframe>
</Layout>
