---
// components
import Breadcrumbs from "@/components/navigation/Breadcrumbs";
import Container from "@/components/Container";
import Photo from "@/components/images/Photo";

// functions
import { getImage } from "@/functions/Media";

// props
export interface Props {
    image: string;
    title: string;
}
const { image, title } = Astro.props as Props;
---

<div class="relative min-h-[300px] md:min-h-[600px]">
    <!-- header image -->
    <Photo src={image} width={2000} height={1000} classes="absolute object-cover h-full w-full" />

    <!-- bg -->
    <div class="inset-0 absolute bg-gradient-to-t from-stone-800/90 via-transparent to-transparent"></div>

    <slot />
</div>

<div class="bg-stone-200">
    <Container>
        <div class="flex flex-col-reverse order md:flex-row justify-between py-5 md:items-center gap-4">
            <!-- breadcrumbs -->
            <div>
                <span class="text-stone-800 text-2xl uppercase italic font-extrabold tracking-tighter">{title}</span>
                <div class="text-sm text-stone-500">
                    <Breadcrumbs path={Astro.url.pathname} />
                </div>
            </div>

            <!-- metadata -->
            <div class="flex flex-col md:text-right max-w-md">
                <div class="text-stone-700">{getImage(image).title}</div>
                <div class="text-stone-500 text-sm font-light line-clamp-1" title={getImage(image).description}>{getImage(image).description}</div>
            </div>
        </div>
    </Container>
</div>
