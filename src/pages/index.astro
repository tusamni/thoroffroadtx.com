---
// layouts
import Layout from "../layouts/Layout.astro";

// components
import { Image } from "@astrojs/image/components";
import Button from "@/components/buttons/Button";
import Link from "@/components/buttons/LinkArrow";
import Container from "@/components/Container";

// images
const carli = [
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/F-250/2205-2022-Ford-F-250-Grey/_07A1493.jpg",
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/Bronco/2203-2022-Ford-Bronco-Wild-Track-Grey/_07A9839.jpg",
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/_07A2427.jpg",
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/F-250/2206-2022-Ford-F-250-Grey/IMG_6714.JPG",
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/F-250/2207-2022-Ford-F-250-Lariat-White/_07A3140.jpg",
    "https://ik.imagekit.io/eriksolsen/Images/Vehicles/Ford/F-350/2205-2022-Ford-F-350-XLT-Grey/_07A0466.jpg",
];
---

<Layout title="Welcome to Astro.">
    <div class="relative flex items-center justify-start h-[50vh]">
        <Container>
            <div class="relative z-20 w-full flex flex-col gap-6">
                <div class="flex flex-col gap-2">
                    <h1>Purpose-Built Vehicles</h1>
                    <div class="text-2xl max-w-xl text-white">
                        We are experts in designing and building off-road vehicles that deliver the exact performance and style that our customers dream about.
                    </div>
                </div>

                <div class="flex gap-6">
                    <Button text="Get in Touch" url="/contact">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path
                                d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"
                            ></path>
                        </svg>
                    </Button>
                    <Button text="THOR in Action!" url="#" theme="secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM6.79 5.093A.5.5 0 0 0 6 5.5v5a.5.5 0 0 0 .79.407l3.5-2.5a.5.5 0 0 0 0-.814l-3.5-2.5z"></path>
                        </svg>
                    </Button>
                </div>
            </div>
        </Container>

        <div class="bg-gradient-to-tl from-red-500/60 via-neutral-700/90 to-neutral-900 absolute w-full h-full z-10"></div>
        <Image src="https://ik.imagekit.io/eriksolsen/Images/Vehicles/RAM/1500/2100-2021-RAM-1500-TRX-White/_07A9525.jpg" width={2500} height={2500} class="absolute object-cover w-full h-[50vh]" />
        <!-- <video autoplay muted loop class="absolute object-cover w-full h-[50vh]">
            <source src="https://ik.imagekit.io/eriksolsen/videos/homepage/roller_v2.mp4?tr=w-300,h-300" type="video/mp4" />
        </video> -->
    </div>

    <div class="bg-blue-200 py-28">
        <div class="flex flex-col gap-8 space-y-8">
            <Container>
                <div class="flex items-start justify-between gap-24">
                    <Image src="https://ik.imagekit.io/eriksolsen/images/brands/parts/color/carli-suspension.png" width={287} height={116} class="" />

                    <div class="flex flex-col gap-4">
                        <h2 class="h3 text-blue-900">Texas' Only Carli Stocking Dealer</h2>
                        <p class="text-lg font-light text-blue-800">
                            As <i>the only Carli Suspension Stocking Dealer in Texas</i>, nobody carries more Carli parts or knows the performance suspension options for your vehicle better than THOR
                            Off-Road.
                        </p>
                    </div>
                </div>
            </Container>

            <div class="grid grid-cols-6 gap-4 px-4">
                {carli.map((i) => <Image src={i} width={300} height={300} class="h-auto w-full rounded-sm object-cover shadow-xl" />)}
            </div>

            <div class="flex justify-center">
                <Link text="Get a Quote for Your Carli Install" url="#" textSize="text-xl" />
            </div>
        </div>
    </div>

    <div class="relative bg-tan-500 py-40">
        <Container classes="flex gap-16">
            <Image src="https://ik.imagekit.io/eriksolsen/Images/Team/Jamey/DSC08086-2.jpg" width={1875} height={2500} class="w-1/2 object-cover object-right shadow-2xl rounded-sm" />

            <div class="space-y-16 py-12">
                <div class="space-y-8">
                    <h2 class="h1 text-gray-900">The THOR Difference</h2>
                    <p class="text-2xl font-medium text-gray-600 tracking-wide leading-9">
                        THOR is the premiere truck and off-road vehicle outfitter in Texas with the unique automotive knowledge, technical expertise, and deep customer insights to consistently deliver
                        the truck or adventure vehicle of our customers' dreams. Come experience your own purpose-built vehicle.
                    </p>
                    <p class="text-gray-500 leading-9 text-light text-xl">
                        THOR is passionate about creating purpose-built vehicles for our customers, but we also thrive on building strong personal relationships that are based on competence and trust.
                        We are experts in all things off-road and love to inspire and help our customers to build the truck or adventure vehicle that they have always wanted. We aren't satisfied until
                        we hear our customers say, “Wow, I can't believe that's my truck!”
                    </p>
                </div>

                <div class="space-y-4">
                    <Image src="https://ik.imagekit.io/eriksolsen/Images/Team/Jamey/signature.png" width={394} height={98} class="w-72" />
                    <p class="font-medium text-gray-400">Owner, THOR Off-Road</p>
                </div>
            </div>
        </Container>
    </div>
</Layout>
