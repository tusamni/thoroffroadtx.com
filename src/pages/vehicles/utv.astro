---
// layouts
import Vehicle from "@/layouts/Vehicle";

// components
import { getImage } from "@/functions/Media";

// content
export const models = await Astro.glob("./utv/**/*.astro");
export const content = {
    title: "UTV",
    subtitle: "Get Outside",
    description:
        "Side by Side vehicles are the hardest working and smoothest riding side vehicles that you can get for off roading, ranch work, and hunting. We work on the top brands of utility terrain vehicles (UTV) and side-by-sides (SXS) including Polaris, Honda, Can Am, Kawasaki, and Yamaha.",
};

// images
export const images = {
    logo: "brands/manufacturers/toyota",
    photo: getImage("vehicles/ford/f-250/2110-2021-ford-f-250-lariat-de-tremor-lithium-grey/2021-ford-f-250-lariat-de-tremor-lithium-grey_003"),
};
---

<Vehicle content={content} images={images} models={models} />
