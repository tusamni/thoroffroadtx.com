export async function getStaticPaths() {
    const vehicles = await Astro.glob("../../../data/vehicles/*.json");
    const make = vehicles[0].slug;

    return vehicles[0].models.map((m) => ({
        params: { make: make, model: m.slug },
        props: m,
    }));
}

const { make, model } = Astro.params;
const {} = Astro.props;
