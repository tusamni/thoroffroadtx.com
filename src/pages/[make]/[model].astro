---
export async function getStaticPaths() {
    const vehicles = await Astro.glob("../../data/vehicles/*.json");

    return vehicles.map((file) => ({
        params: { slug: file.slug },
        props: file,
    }));
}

const { slug } = Astro.params;
const { title, subheading } = Astro.props;
---

{title}
