---
// components
import { Icon } from "astro-icon";
import Container from "@/components/Container";

export interface Props {
    name: string;
    menu: any;
    target: string;
    url: string;
}
const { name, menu, target, url } = Astro.props as Props;
---

<div
    class="py-10 px-4"
    x-data={`{ ${target} : true }`}
    x-on:mouseenter={`${target} = true`}
    x-on:mouseover.away={`${target} = false`}
    x-on:click={`${target} = true`}
    :class={`${target} ? 'bg-white' : ''`}
>
    <button class="flex gap-1 lg:gap-2">
        <div class="flex gap-2">
            {name}
            <Icon name="bi:caret-down" class="w-3 h-auto" x-show={`!${target}`} />
            <Icon name="bi:caret-down-fill" class="w-3 h-auto" x-show={`${target}`} />
        </div>
    </button>

    <div x-show={target} class="absolute top-[100px] inset-0 w-full z-30">
        <div class="bg-white w-full">
            <Container classes="py-8">
                <div class="grid grid-cols-4 lg:grid-cols-4 gap-2 lg:gap-4">
                    {
                        menu.map((m) => (
                            <a
                                href={m.url}
                                title={m.name}
                                class="group relative flex items-center rounded-md border border-neutral-200 p-2 md:px-4 md:py-3 lg:p-0"
                            >
                                <div class="hidden h-full w-12 items-center bg-neutral-200 p-2 lg:flex">
                                    <Icon name={m.logo} class="w-12 text-neutral-400" />
                                </div>

                                <div class="z-10 flex h-full w-full flex-col p-2 group-hover:bg-neutral-100">
                                    <div class="text-lg font-medium group-hover:underline">{m.name}</div>
                                    <p class="line-clamp-2 text-sm font-light">{m.listing.map((l, index) => (index ? ", " : "") + l)}</p>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </Container>
        </div>
    </div>
</div>
