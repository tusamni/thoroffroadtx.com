---
// components
import { Icon } from "astro-icon";
import Container from "@/components/Container";

export interface Props {
    name: string;
    target: string;
    url: string;
}
const { name, target, url } = Astro.props as Props;
---

<div
    class="py-10 px-4"
    x-data=`{ ${target} : false }`
    x-on:mouseenter=`${target} = true`
    x-on:mouseover.away=`${target} = false`
    x-on:click=`${target} = true`
    :class=`${target} ? 'bg-white' : ''`
>
    <button class="flex gap-1 lg:gap-2">
        <div class="flex gap-2">
            {name}
            <Icon name="bi:caret-down" class="w-3 h-auto" />
        </div>
    </button>

    <div x-show={target}>
        <div class="absolute top-[100px] inset-0 w-full z-30">
            <div class="bg-white w-full">
                <Container classes="py-8">
                    <div class="flex flex-row">
                        <slot />
                    </div>
                </Container>
            </div>
        </div>
    </div>
</div>
