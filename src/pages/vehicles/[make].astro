---
// layouts
import Layout from "@/layouts/Vehicle";

export async function getStaticPaths() {
    const vehicles = await Astro.glob("../../data/vehicles/*.json");

    return vehicles.map((v) => ({
        params: { make: v.slug },
        props: v,
    }));
}

const { make } = Astro.params;
const { title, heading, subheading, featured, logo } = Astro.props;
---

<Layout title={title} heading={heading} subheading={subheading} featured={featured} logo={logo} />
