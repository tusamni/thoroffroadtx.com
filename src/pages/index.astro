---
// layouts
import Layout from "@/layouts/Layout";

// components
import { Icon } from "astro-icon";
import Button from "@/components/buttons/Button";
import Container from "@/components/Container";
import Gallery from "@/components/images/Gallery";
import Link from "@/components/buttons/Link";
import Photo from "@/components/images/Photo";

// config
import { imageConfig } from "@/src/config";

// images
const carli = {
    logo: "brands/parts/color/carli-suspension.png",
    recent: [
        "vehicles/ford/f-250/2110-2021-ford-f-250-lariat-de-tremor-lithium-grey/2021-ford-f-250-lariat-de-tremor-lithium-grey_007.jpg",
        "vehicles/ford/f-350/2110-2021-ford-f-350-king-ranch-black/2021-ford-f-350-king-ranch-black_012.jpg",
        "vehicles/ram/2500/2103-2016-ram-2500-black/2016-ram-2500-black_051.jpg",
        "vehicles/ford/f-250/2206-2022-ford-f-250-stone-grey/2022-ford-f-250-stone-grey_002.jpg",
    ],
};
const jamey = {
    portrait: "team/jamey/jamey-01.jpg",
    signature: "team/jamey/signature.png",
};
const builds = [
    "vehicles/ford/f-250/2204-2016-ford-f-250-white/2016-ford-f-250-white_015.jpg",
    "vehicles/ford/f-250/2206-2022-ford-f-250-stone-grey/2022-ford-f-250-stone-grey_005.jpg",
    "vehicles/ford/f-250/2110-2021-ford-f-250-lariat-de-tremor-lithium-grey/2021-ford-f-250-lariat-de-tremor-lithium-grey_004.jpg",
    "vehicles/ford/bronco/2206-2021-ford-bronco-wild-track-antimatter-blue/2021-ford-bronco-wild-track-antimatter-blue_019.jpg",
    "vehicles/ford/bronco/2112-2021-ford-bronco-badlands-oxford-white/2021-ford-bronco-badlands-oxford-white_001.jpg",
    "vehicles/gmc/2500/2203-2021-gmc-2500-at4-white/2021-gmc-2500-at4-white_002.jpg",
    "vehicles/ram/1500/2100-2021-ram-1500-trx-white/2021-ram-1500-trx-white_004.jpg",
    "vehicles/ram/2500/2205-2006-ram-2500-red/2006-ram-2500-red_006.jpg",
    "vehicles/toyota/land-cruiser/2111-2007-toyota-land-cruiser-black/2007-toyota-land-cruiser-black_002.jpg",
    "vehicles/toyota/tacoma/2204-2021-toyota-tacoma-silver/2021-toyota-tacoma-silver_012.jpg",
    "vehicles/ram/2500/2207-2022-ram-2500-limited-white/2022-ram-2500-limited-white_004.jpg",
    "vehicles/ram/2500/2109-2019-ram-2500-limited-white/2019-ram-2500-limited-white_004.jpg",
    "vehicles/ram/2500/2103-2016-ram-2500-black/2016-ram-2500-black_042.jpg",
    "vehicles/lexus/gx/2112-2018-lexus-gx460-silver/2018-lexus-gx460-silver_002.jpg",
    "vehicles/ram/2500/2205-2006-ram-2500-red/2006-ram-2500-red_001.jpg",
];

// videos
const roller = `${imageConfig.cloudUrl}/videos/homepage/roller_v2.mp4`;
---

<Layout>
    <div class="mb-16 md:mb-24">
        <div class="relative flex items-center justify-start py-24 md:py-36">
            <!-- bg video -->
            <video autoplay muted loop class="hidden md:block absolute object-cover w-full h-full">
                <source src={roller} type="video/mp4" />
            </video>
            <Photo
                src="vehicles/ford/f-250/2203-1997-ford-f-250-obs-red/1997-ford-f-250-obs-red_001.jpg"
                height={1000}
                width={1000}
                classes="md:hidden absolute object-cover h-full w-full object-left"
            />

            <div class="bg-gradient-to-tr from-stone-900/90 via-stone-800/70 to-stone-700/20 absolute w-full h-full"></div>

            <Container>
                <div class="relative w-full flex flex-col gap-10">
                    <div class="flex flex-col gap-4">
                        <h1 class="text-stone-100">Purpose-Built Vehicles</h1>
                        <div class="text-lg md:text-2xl max-w-xl text-stone-200">
                            We are experts in designing and building off-road vehicles that deliver the exact performance and style that our customers
                            dream about.
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 md:gap-6 items-center">
                        <Button text="Get in Touch" href="/contact" theme="btn-secondary" classes="w-full sm:w-fit">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                                <path
                                    d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"
                                ></path>
                            </svg>
                        </Button>

                        <div x-data="videoModal()">
                            <Link href="#" text="Watch THOR in Action!" classes="text-white flex justify-center text-lg" x-on:click="open" />
                            <!-- modal -->
                            <div
                                style="display: none"
                                x-show="isOpen()"
                                x-transition:enter="transition ease-in-out duration-300"
                                x-transition:enter-start="opacity-0"
                                x-transition:leave="transition ease-in-in duration-300"
                                x-transition:leave-end="opacity-0"
                                x-on:click="close"
                                x-on:keydown.window.escape="close"
                                class="z-50 fixed inset-0 bg-black bg-opacity-80 flex justify-center items-center"
                            >
                                <iframe
                                    id="modalVideo"
                                    class="w-full h-full max-w-[80%] max-h-[80%]"
                                    width="560"
                                    height="315"
                                    src="https://www.youtube.com/embed/3yk13_c56DA?enablejsapi=1"
                                    title="THOR Off-Road in Action"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </Container>
        </div>

        <div class="space-y-24 md:space-y-40">
            <!-- featured Carli section -->
            <div class="bg-gradient-to-br from-blue-100 to-blue-300 py-16 md:py-24">
                <Container classes="space-y-8">
                    <div class="flex flex-row items-center justify-between gap-12">
                        <Photo src={carli.logo} alt="Carli Logo" width={287} height={116} classes="hidden lg:block" />

                        <div class="flex flex-col gap-4">
                            <h2 class="text-cyan-900">Texas' Only Carli Stocking Dealer</h2>
                            <p class="text-lg text-stone-600">
                                As <i>the only Carli Suspension Stocking Dealer in Texas</i>, nobody carries more Carli parts or knows the performance
                                suspension options for your vehicle better than THOR Off-Road.
                            </p>
                        </div>
                    </div>

                    <Gallery
                        images={carli.recent}
                        galleryClasses="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-4"
                        imageClasses="shadow-2xl rounded-sm"
                        thumbnailWidth={600}
                        thumbnailHeight={600}
                    />

                    <div class="flex justify-center">
                        <Link text="Get a Quote for Your Carli Install" href="/contact" classes="text-xl" />
                    </div>
                </Container>
            </div>

            <!-- Jamey quote -->
            <div class="relative overflow-hidden">
                <Container classes="relative z-10 flex flex-col lg:flex-row gap-8 lg:gap-16">
                    <Photo
                        src={jamey.portrait}
                        height={1500}
                        width={1200}
                        alt="Jamey from THOR Off-Road"
                        classes="w-full lg:w-1/2 object-cover object-[65%] shadow-2xl rounded-sm"
                    />

                    <div class="space-y-16">
                        <div class="space-y-8">
                            <h2 class="h1 text-gray-900">The THOR Difference</h2>
                            <p class="text-xl md:text-2xl font-medium text-gray-600 tracking-wide leading-8 md:leading-9">
                                THOR is the premiere truck and off-road vehicle outfitter in Texas with the unique automotive knowledge, technical
                                expertise, and deep customer insights to consistently deliver the truck or adventure vehicle of our customers' dreams.
                                Come experience your own purpose-built vehicle.
                            </p>
                            <p class="text-gray-500 leading-8 text-extralight text-lg">
                                THOR is passionate about creating purpose-built vehicles for our customers, but we also thrive on building strong
                                personal relationships that are based on competence and trust. We are experts in all things off-road and love to
                                inspire and help our customers to build the truck or adventure vehicle that they have always wanted. We aren't
                                satisfied until we hear our customers say, “Wow, I can't believe that's my truck!”
                            </p>
                        </div>

                        <div class="space-y-2 flex flex-col items-center">
                            <Photo src={jamey.signature} width={394} height={98} alt="Jamey signature" class="w-52 sm:w-72" />
                            <p class="font-medium text-gray-400">Owner, THOR Off-Road</p>
                        </div>
                    </div>
                </Container>

                <Icon name="tracks/tire-tracks_01" class="absolute bottom-0 right-0 text-stone-200/30 w-[500px]" />
                <Icon name="tracks/tire-tracks_01" class="absolute top-0 left-0 text-stone-200/30 w-[500px] rotate-180" />
            </div>

            <Container classes="space-y-12">
                <div class="flex flex-col md:flex-row justify-between items-center">
                    <h2 class="text-gray-900">Recent Builds</h2>
                    <Link text="See More Photos" href="/gallery" classes="text-xl" />
                </div>

                <Gallery
                    images={builds}
                    galleryClasses="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-4"
                    imageClasses="shadow-lg rounded-sm"
                    thumbnailWidth={600}
                    thumbnailHeight={600}
                />
            </Container>
        </div>
    </div>
</Layout>

<script is:inline>
    function videoModal() {
        return {
            show: false,

            isOpen() {
                return this.show;
            },

            open($event) {
                this.show = true;
            },

            close() {
                this.show = false;
                // stop playing video on hide
                document.getElementById("modalVideo").contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', "*");
            },
        };
    }
</script>
