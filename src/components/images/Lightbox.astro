---
import { Image } from "@astrojs/image/components";

// functions
import { getImage } from "@/functions/Media";

// props
export interface Props {
    src: string;
    classes?: string;
}
const { src, classes } = Astro.props as Props;

const lightbox = await getImage(src);
---

<a href={lightbox.src} class={classes} data-sub-html={`<div class="text-xl font-medium">${lightbox.title}</div><div class="font-light">${lightbox.description}</div>`}>
    <Image src={lightbox.src} width={500} height={500} class={classes} alt={lightbox.alt} />

    <div class="caption hidden">
        <div class="text-xl font-medium">{lightbox.title}</div>
        <div class="font-light">{lightbox.description}</div>
    </div>
</a>
