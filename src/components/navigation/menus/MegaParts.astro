---
// components
import { Icon } from "astro-icon";
import Container from "@/components/Container";

// get vehicle data
const parts = await Astro.glob("../../../pages/parts/*.astro");
---

<div
    class="py-10 px-4"
    x-data={`{ partsMega : true }`}
    x-on:mouseenter={`partsMega = true`}
    x-on:mouseover.away={`partsMega = false`}
    x-on:click={`partsMega = true`}
    :class={`partsMega ? 'bg-white' : ''`}
>
    <button class="flex gap-1 lg:gap-2">
        <div class="flex gap-2">
            Parts
            <Icon name="bi:caret-down" class="w-3 h-auto" x-show={`!partsMega`} />
            <Icon name="bi:caret-down-fill" class="w-3 h-auto" x-show={`partsMega`} />
        </div>
    </button>

    <div x-show="partsMega" class="absolute top-[100px] inset-0 w-full z-30">
        <div class="bg-white w-full">
            <Container classes="py-8">
                <div class="grid grid-cols-4 lg:grid-cols-4 gap-2 lg:gap-4">
                    {
                        parts.map((p) => (
                            <a
                                href={p.url}
                                title={p.content.title}
                                class="group relative flex items-center rounded-md border border-stone-200 p-2 md:px-4 md:py-3 lg:p-0"
                            >
                                <div class="hidden h-full w-12 items-center bg-stone-200 p-2 lg:flex">
                                    <Icon name={p.images.logo} class="w-12 text-stone-400" />
                                </div>

                                <div class="z-10 flex h-full w-full flex-col p-4 group-hover:bg-stone-100">
                                    <div class="text-lg font-medium group-hover:underline">{p.content.title}</div>
                                    <p class="line-clamp-2 text-sm font-light">{p.brands.map((b, index) => (index ? ", " : "") + b.name)}</p>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </Container>
        </div>
    </div>
</div>
