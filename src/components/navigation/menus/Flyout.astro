---
// components
import { Icon } from "astro-icon";
import { getImage } from "@astrojs/image";
import { Image } from "@astrojs/image/components";
import Accordion from "@/components/navigation/menus/Accordion";
import Button from "@/components/buttons/Button";
import Container from "@/components/Container";

import { imageConfig } from "@/src/config";

// data
import { Business, Social } from "@/data/business";

// functions
import { getPublicPath } from "@/functions/Media";

// images
const logo = getPublicPath("/Images/Website/Logos/logo-black.svg");
const icon = `${imageConfig.cloudUrl}/Images/Vehicles/Ford/F-250/2110-2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey/2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey_003.jpg`;
const iconImage = await getImage({
    src: icon,
    width: 100,
    height: 100,
});
---

<div class="fixed top-[90px] right-0 z-50 w-full h-screen overflow-y-scroll bg-tan-200" x-on:click.outside={"flyout = false"}>
    <Container>
        <div class="space-y-12">
            <!-- links -->
            <div class="pt-12 space-y-4">
                <!-- vehicles -->
                <Accordion name="Vehicles" target="vehiclesAccordion" url="">
                    {
                        [...Array(8)].map((d) => (
                            <div class="grid grid-cols-4 gap-2">
                                <div
                                    style={`background-image: url(${iconImage.src}); background-repeat: no-repeat; background-size: cover; background-position: center`}
                                    class="max-w-20 h-auto rounded-sm"
                                />

                                <div class="col-span-3">
                                    <div class="font-medium">Chevrolet</div>
                                    <p class="text-xs font-light">Colorado, Canyon, Silverado, Sierra, Tahoe & Yukon.</p>
                                </div>
                            </div>
                        ))
                    }
                </Accordion>

                <!-- parts -->
                <Accordion name="Parts" target="partsAccordion" url="">
                    {
                        [...Array(8)].map((d) => (
                            <div class="grid grid-cols-4 gap-2">
                                <div
                                    style={`background-image: url(${iconImage.src}); background-repeat: no-repeat; background-size: cover; background-position: center`}
                                    class="max-w-20 h-auto rounded-sm"
                                />

                                <div class="col-span-3">
                                    <div class="font-medium">Chevrolet</div>
                                    <p class="text-xs font-light">Colorado, Canyon, Silverado, Sierra, Tahoe & Yukon.</p>
                                </div>
                            </div>
                        ))
                    }
                </Accordion>

                <!-- other links -->
                <h4 class="text-3xl text-black">Gallery</h4>
                <h4 class="text-3xl text-black">Social Feed</h4>
            </div>

            <!-- cta buttons -->
            <div class="space-y-2">
                <Button text="Contact Us" url="/contact" theme="secondary" classes="">
                    <Icon name="bi:envelope" class="w-3 h-auto" />
                </Button>

                <Button text="Call Us" url="/contact">
                    <Icon name="bi:telephone" class="w-3 h-auto" />
                </Button>
            </div>

            <!-- social icons -->
            <div class="flex gap-6 justify-around">
                {
                    Social.map((i) => (
                        <a href={i.url} target="_blank" title={`${Business.name_long} ${i.title}`}>
                            <Icon name={i.icon} class="h-auto w-5 text-neutral-700" />
                        </a>
                    ))
                }
            </div>
        </div>
    </Container>
</div>
