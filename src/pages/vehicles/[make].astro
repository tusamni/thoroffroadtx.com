---
// layouts
import Layout from "@/layouts/Layout";

// components
import { Icon } from "astro-icon";
import { Image } from "@astrojs/image/components";
import Breadcrumbs from "@/components/Breadcrumbs";
import Container from "@/components/Container";
import Link from "@/components/buttons/Link";
import Metadata from "@/components/images/Metadata";

// functions
import { getImage, getPublicPath } from "@/functions/Media";
import { getModels } from "@/functions/Vehicles";

export async function getStaticPaths() {
    const vehicles = await Astro.glob("../../data/vehicles/*.json");

    return vehicles.map((v) => ({
        params: { make: v.slug },
        props: v,
    }));
}

const { make } = Astro.params;
const { title, heading, subheading, featured, logo } = Astro.props;

const models = await getModels(make);
const images = {
    featured: getImage(featured),
};

console.log(models);
---

<Layout>
    <!-- headline image -->
    <div class="relative h-[600px]">
        <Image
            src={images.featured.src}
            alt={images.featured.alt}
            width={2000}
            aspectRatio={images.featured.aspectRatio}
            class="absolute object-cover h-full w-full"
        />

        <!-- bg -->
        <div class="inset-0 absolute bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <!-- headline metadata -->
        <Metadata title={images.featured.title} description={images.featured.description} />
    </div>

    <Breadcrumbs path={Astro.url.pathname} />

    <!-- summary -->
    <div class="bg-white py-40 relative">
        <Icon name={logo} class="absolute -bottom-[3%] right-0 w-[850px] h-auto text-stone-100" />

        <Container>
            <div class="space-y-52">
                <div class="max-w-3xl space-y-8">
                    <h1 class="text-stone-800">{heading}</h1>
                    <p class="text-stone-600 text-xl leading-9">
                        {subheading}
                    </p>
                </div>
            </div>
        </Container>
    </div>

    <!-- model listing -->
    <div class="bg-stone-100 py-40 relative overflow-hidden">
        <Icon name="tracks/tire-tracks_05" class="absolute -top-20 -left-20 w-[800px] text-stone-300/20" />
        <Icon name="tracks/tire-tracks_03" class="absolute -bottom-20 -left-20 w-[800px] text-stone-300/20 rotate-90" />

        <Container classes="relative space-y-24">
            {
                models.map((m) => (
                    <div>
                        <div>
                            <div class="relative flex">
                                <div class="flex min-w-fit items-center rounded-tl-sm bg-stone-200 px-8">
                                    <h2 class="text-stone-700">{m.content.title}</h2>
                                </div>
                                <div class="col-span-2 rounded-tr-sm bg-stone-200/90 p-8 text-lg text-stone-600">{m.content.description}</div>
                            </div>

                            <Image
                                src={m.images.photo.src}
                                alt={m.images.photo.alt}
                                width={1300}
                                height={600}
                                class="col-span-3 h-[600px] rounded-sm object-cover shadow-2xl"
                            />
                        </div>

                        <div class="flex items-center">
                            <div class="w-full text-lg font-light italic text-stone-700">{m.images.photo.title}</div>

                            <div class="bg-yellow-500 py-5 px-6">
                                <Link
                                    text={`Customize Your ${m.content.title}!`}
                                    href="/contact"
                                    classes="text-yellow-900 text-xl whitespace-nowrap"
                                />
                            </div>
                        </div>
                    </div>
                ))
            }
        </Container>
    </div>
</Layout>
