---
import { Image } from "@astrojs/image/components";

// functions
import { getImage } from "@/functions/Media";

// props
export interface Props {
    src: string;
    classes?: string;
}
const { src, classes } = Astro.props as Props;

const lightbox = await getImage(src);
---

<a href={lightbox.src} data-img={lightbox.src} data-alt={lightbox.description} data-height={lightbox.height} data-width={lightbox.width} data-caption={lightbox.description}>
    <img src={lightbox.src} class:list={[classes]} width={500} height={500} alt={lightbox.alt} />
</a>
