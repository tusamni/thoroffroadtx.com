---
// components
import { Icon } from "astro-icon";
import { Picture } from "@astrojs/image/components";
import Accordion from "@/components/navigation/menus/Accordion";
import Button from "@/components/buttons/Button";
import Container from "@/components/Container";

// data
import { business, social } from "@/data/business";

// functions
import { getImage } from "@/functions/Media";

// images
const thumbnail = await getImage(
    "/Images/Vehicles/Ford/F-250/2110-2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey/2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey_003.jpg"
);
---

<div class="fixed top-[90px] inset-0 z-50 w-full overflow-y-scroll bg-tan-200" x-on:click.outside={"flyout = false"}>
    <Container>
        <div class="py-12 space-y-12">
            <!-- links -->
            <div class="space-y-4">
                <!-- vehicles -->
                <Accordion name="Vehicles" target="vehiclesAccordion" url="">
                    {
                        [...Array(8)].map((d) => (
                            <div class="grid grid-cols-4 gap-2">
                                <div class="max-h-24 w-auto">
                                    <Picture
                                        src={thumbnail.src}
                                        widths={[100, 250, 500]}
                                        sizes="(max-width: 800px) 100vw, 800px"
                                        aspectRatio={thumbnail.aspectRatio}
                                        class="rounded-sm object-cover"
                                    />
                                </div>

                                <div class="col-span-3">
                                    <div class="font-medium">Chevrolet</div>
                                    <p class="text-xs font-light">Colorado, Canyon, Silverado, Sierra, Tahoe & Yukon.</p>
                                </div>
                            </div>
                        ))
                    }
                </Accordion>

                <!-- other links -->
                <h4 class="text-3xl text-black">Gallery</h4>
                <h4 class="text-3xl text-black">Social Feed</h4>
            </div>

            <!-- cta buttons -->
            <div class="space-y-2">
                <Button text="Contact Us" url="/contact" theme="secondary">
                    <Icon name="bi:envelope" class="w-3 h-auto" />
                </Button>

                <Button text="Call Us" url="/contact">
                    <Icon name="bi:telephone" class="w-3 h-auto" />
                </Button>
            </div>

            <!-- social icons -->
            <div class="flex gap-6 justify-around">
                {
                    social.map((i) => (
                        <a href={i.url} target="_blank" title={`${business.name_long} ${i.title}`}>
                            <Icon name={i.icon} class="h-auto w-5 text-neutral-700" />
                        </a>
                    ))
                }
            </div>
        </div>
    </Container>
</div>
