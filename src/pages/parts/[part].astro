---
// layouts
import Layout from "@/layouts/Layout";

// components
import Container from "@/components/Container";
import Hero from "@/components/Hero";
import Photo from "@/components/images/Photo";

// functions
import { getImage } from "@/functions/Media";

export async function getStaticPaths() {
    const vehicles = await Astro.glob("../../data/parts/*.json");

    return vehicles.map((p) => ({
        params: { part: p.slug },
        props: p,
    }));
}

const { part } = Astro.params;
const { title, heading, descriptionLong, featured, brands, logo } = Astro.props;
---

<Layout>
    <Hero image={featured} title={title} />

    <!-- summary -->
    <div class="bg-white py-40">
        <Container>
            <div class="space-y-20">
                <div class="space-y-12">
                    <div class="max-w-3xl space-y-8">
                        <h1 class="text-stone-800">{heading}</h1>
                        <p class="text-stone-600 text-xl leading-9">{descriptionLong}</p>
                    </div>
                    <div class="space-y-4">
                        <div class="flex gap-10 items-center overflow-hidden relative w-fit">
                            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/50 to-white"></div>
                            {
                                brands
                                    .map((b) => (
                                        <img src={getImage(`brands/parts/grayscale/brands_${b.logo}.png`).src} alt={b.title} class="h-12 w-auto" />
                                    ))
                                    .splice(0, 5)
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </div>
</Layout>
