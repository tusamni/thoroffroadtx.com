---
// layouts
import Layout from "@/layouts/Layout";

// components
import { Icon } from "astro-icon";
import { Image } from "@astrojs/image/components";
import Button from "@/components/buttons/Button";
import Gallery from "@/components/images/Gallery";
import Link from "@/components/buttons/Link";
import Container from "@/components/Container";

// functions
import { getImage, getPublicPath } from "@/functions/Media";

// images
const carli = {
    logo: getPublicPath("/images/brands/parts/color/carli-suspension.png"),
    recent: [
        await getImage("vehicles/ford/f-250/2110-2021-ford-f-250-lariat-de-tremor-lithium-grey/2021-ford-f-250-lariat-de-tremor-lithium-grey_007"),
        await getImage("vehicles/ram/2500/2207-2022-ram-2500-limited-white/2022-ram-2500-limited-white_013"),
        await getImage("vehicles/ram/2500/2103-2016-ram-2500-black/2016-ram-2500-black_051"),
        await getImage("vehicles/ford/f-250/2206-2022-ford-f-250-stone-grey/2022-ford-f-250-stone-grey_002"),
    ],
};
const jamey = {
    portrait: getPublicPath("/images/team/jamey/jamey-01.jpg"),
    signature: getPublicPath("/images/team/jamey/signature.png"),
};
const builds = [
    await getImage("vehicles/ford/f-350/2204-2016-ford-f-350-white/2016-ford-f-350-white_015"),
    await getImage("vehicles/ford/f-250/2206-2022-ford-f-250-stone-grey/2022-ford-f-250-stone-grey_005"),
    await getImage("vehicles/ford/f-250/2110-2021-ford-f-250-lariat-de-tremor-lithium-grey/2021-ford-f-250-lariat-de-tremor-lithium-grey_004"),
    await getImage("vehicles/ford/bronco/2206-2021-ford-bronco-wild-track-antimatter-blue/2021-ford-bronco-wild-track-antimatter-blue_019"),
    await getImage("vehicles/ford/bronco/2112-2021-ford-bronco-badlands-oxford-white/2021-ford-bronco-badlands-oxford-white_001"),
    await getImage("vehicles/gmc/2500/2203-2021-gmc-2500-at4-white/2021-gmc-2500-at4-white_002"),
    await getImage("vehicles/ram/1500/2100-2021-ram-1500-trx-white/2021-ram-1500-trx-white_004"),
    await getImage("vehicles/ram/2500/2205-2006-ram-2500-red/2006-ram-2500-red_006"),
    await getImage("vehicles/toyota/land-cruiser/2111-2007-toyota-land-cruiser-black/2007-toyota-land-cruiser-black_002"),
    await getImage("vehicles/toyota/tacoma/2204-2021-toyota-tacoma-silver/2021-toyota-tacoma-silver_012"),
    await getImage("vehicles/ram/2500/2207-2022-ram-2500-limited-white/2022-ram-2500-limited-white_004"),
    await getImage("vehicles/ram/2500/2109-2019-ram-2500-limited-white/2019-ram-2500-limited-white_004"),
    await getImage("vehicles/ram/2500/2103-2016-ram-2500-black/2016-ram-2500-black_042"),
    await getImage("vehicles/lexus/gx/2112-2018-lexus-gx460-silver/2018-lexus-gx460-silver_002"),
];

// videos
const roller = getPublicPath("/videos/homepage/roller_v2.mp4");
const hero = getPublicPath("/videos/homepage/thor-in-action.mp4");
---

<Layout>
    <div class="relative flex items-center justify-start py-32 md:py-52">
        <Container>
            <div class="relative z-20 w-full flex flex-col gap-10">
                <div class="flex flex-col gap-4">
                    <h1>Purpose-Built Vehicles</h1>
                    <div class="text-lg md:text-2xl max-w-xl text-white">
                        We are experts in designing and building off-road vehicles that deliver the exact performance and style that our customers
                        dream about.
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row gap-4">
                    <Button text="Get in Touch" href="/contact" classes="w-fit">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path
                                d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"
                            ></path>
                        </svg>
                    </Button>

                    <Button text="THOR in Action!" theme="btn-secondary" classes="w-fit">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path
                                d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM6.79 5.093A.5.5 0 0 0 6 5.5v5a.5.5 0 0 0 .79.407l3.5-2.5a.5.5 0 0 0 0-.814l-3.5-2.5z"
                            ></path>
                        </svg>
                    </Button>
                </div>
            </div>
        </Container>

        <!-- red gradient -->
        <div class="bg-gradient-to-tl from-blue-500 via-neutral-800/50 to-neutral-800/40 absolute w-full h-full z-10"></div>

        <!-- bg video -->
        <video autoplay muted loop class="absolute object-cover w-full h-full">
            <source src={roller} type="video/mp4" />
        </video>
    </div>

    <!-- featured Carli section -->
    <div class="bg-blue-200 py-28 relative overflow-hidden">
        <Icon name="car-parts/coilover_fill" class="absolute -bottom-32 left-0 text-blue-300/60 w-[900px] -rotate-45" />

        <div class="relative z-10 flex flex-col gap-8 space-y-8">
            <Container classes="space-y-8">
                <div class="flex flex-col lg:flex-row items-start justify-between gap-12 lg:gap-24">
                    <Image src={carli.logo} alt="Carli Logo" width={287} height={116} />

                    <div class="flex flex-col gap-4">
                        <h2 class="text-blue-900">Texas' Only Carli Stocking Dealer</h2>
                        <p class="text-lg text-blue-800">
                            As <i>the only Carli Suspension Stocking Dealer in Texas</i>, nobody carries more Carli parts or knows the performance
                            suspension options for your vehicle better than THOR Off-Road.
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                    {
                        carli.recent.map((i) => (
                            <Image
                                src={i.src}
                                width={500}
                                height={500}
                                alt={i.alt}
                                class="h-18 w-full rounded-sm object-cover shadow-xl lg:h-[24rem]"
                            />
                        ))
                    }
                </div>

                <div class="flex justify-between items-center">
                    <div class="hidden lg:flex gap-2">
                        <h4 class="text-blue-900">Recent Carli Builds</h4>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-3 h-auto" viewBox="0 0 16 16">
                            <path
                                fill-rule="evenodd"
                                d="M14 2.5a.5.5 0 0 0-.5-.5h-6a.5.5 0 0 0 0 1h4.793L2.146 13.146a.5.5 0 0 0 .708.708L13 3.707V8.5a.5.5 0 0 0 1 0v-6z"
                            ></path>
                        </svg>
                    </div>
                    <Link text="Get a Quote for Your Carli Install" href="/contact" classes="text-xl" />
                </div>
            </Container>
        </div>
    </div>

    <!-- Jamey quote -->
    <div class="relative bg-tan-500 py-40 space-y-60 overflow-hidden">
        <Container classes="z-10 relative flex flex-col lg:flex-row gap-8 lg:gap-16">
            <Image
                src={jamey.portrait}
                height={1500}
                width={1200}
                alt="Jamey from THOR Off-Road"
                class="w-full lg:w-1/2 object-cover object-[65%] shadow-2xl rounded-sm"
            />

            <div class="space-y-16 py-12">
                <div class="space-y-8">
                    <h2 class="h1 text-gray-900">The THOR Difference</h2>
                    <p class="text-xl md:text-2xl font-medium text-gray-600 tracking-wide leading-8 md:leading-9">
                        THOR is the premiere truck and off-road vehicle outfitter in Texas with the unique automotive knowledge, technical expertise,
                        and deep customer insights to consistently deliver the truck or adventure vehicle of our customers' dreams. Come experience
                        your own purpose-built vehicle.
                    </p>
                    <p class="text-gray-500 leading-8 text-extralight text-lg">
                        THOR is passionate about creating purpose-built vehicles for our customers, but we also thrive on building strong personal
                        relationships that are based on competence and trust. We are experts in all things off-road and love to inspire and help our
                        customers to build the truck or adventure vehicle that they have always wanted. We aren't satisfied until we hear our
                        customers say, “Wow, I can't believe that's my truck!”
                    </p>
                </div>

                <div class="space-y-4">
                    <Image src={jamey.signature} width={394} height={98} alt="Jamey signature" class="w-72" />
                    <p class="font-medium text-gray-400">Owner, THOR Off-Road</p>
                </div>
            </div>
        </Container>

        <Icon name="tracks/tire-tracks_01" class="absolute bottom-0 right-0 text-tan-700/10 w-[500px]" />
        <Icon name="tracks/tire-tracks_01" class="absolute top-0 left-0 text-tan-700/10 w-[500px] rotate-180" />
    </div>

    <div class="space-y-16 bg-tan-500 pt-40 lg:pb-3">
        <Container classes="flex flex-col lg:flex-row justify-between items-center">
            <h2 class="text-gray-900">Recent Builds</h2>
            <Link text="See More Builds" href="/builds" classes="text-xl" />
        </Container>

        <Gallery images={builds} selector="builds" />
    </div>
</Layout>

<script>
    import BiggerPicture from "bigger-picture";

    let bp = BiggerPicture({
        target: document.body,
    });

    // hero video player
    let heroVideo = document.querySelector(".hero-video");
    heroVideo.addEventListener("click", openVideo);

    function openVideo(e) {
        e.preventDefault();

        let items = [
            {
                sources: [{ src: "https://thoroffroad.nyc3.cdn.digitaloceanspaces.com/videos/homepage/thor-in-action.mp4", type: "video/mp4" }],
                height: 720,
                width: 1280,
            },
        ];

        bp.open({
            items: items,
        });
    }
</script>
