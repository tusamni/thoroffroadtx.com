---
// layouts
import Layout from "../layouts/Layout.astro";

// components
import { Icon } from "astro-icon";
import { Image } from "@astrojs/image/components";
import Button from "@/components/buttons/Button";
import Lightbox from "@/components/images/Lightbox";
import Link from "@/components/buttons/LinkArrow";
import Container from "@/components/Container";

// functions
import { getImage, getPublicPath } from "@/functions/Media";

// images
const carli = {
    logo: getPublicPath("/Images/Brands/Parts/Color/carli-suspension.png"),
    recent: [
        await getImage("/Images/Vehicles/GMC/2500/2203-2021-GMC-2500-AT4-White/2021-GMC-2500-AT4-White_001.jpg"),
        await getImage("/Images/Vehicles/GMC/2500/2203-2021-GMC-2500-AT4-White/2021-GMC-2500-AT4-White_001.jpg"),
        await getImage("/Images/Vehicles/GMC/2500/2203-2021-GMC-2500-AT4-White/2021-GMC-2500-AT4-White_001.jpg"),
        await getImage("/Images/Vehicles/GMC/2500/2203-2021-GMC-2500-AT4-White/2021-GMC-2500-AT4-White_001.jpg"),
    ],
};
const hero = await getImage("/Images/Vehicles/Ford/F-250/2110-2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey/2021-Ford-F-250-Lariat-De-Tremor-Lithium-Grey_003.jpg");
const jamey = {
    portrait: getPublicPath("/Images/Team/Jamey/jamey-02.jpg"),
    signature: getPublicPath("/Images/Team/Jamey/signature.png"),
};
const builds = [
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
    "/Images/Vehicles/Ford/Bronco/2206-2021-Ford-Bronco-Wild-Track-Antimatter-Blue/2021-Ford-Bronco-Wild-Track-Antimatter-Blue_011.jpg",
];
---

<Layout title="Welcome to Astro.">
    <div class="relative flex items-center justify-start h-[70vh]">
        <Container>
            <div class="relative z-20 w-full flex flex-col gap-10">
                <div class="flex flex-col gap-4">
                    <h1>Purpose-Building Vehicles</h1>
                    <div class="text-2xl max-w-xl text-white">
                        We are experts in designing and building off-road vehicles that deliver the exact performance and style that our customers dream about.
                    </div>
                </div>

                <div class="flex gap-6">
                    <Button text="Get in Touch" url="/contact">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path
                                d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"
                            ></path>
                        </svg>
                    </Button>
                    <Button text="THOR in Action!" url={getPublicPath("/Videos/Homepage/thor-in-action.mp4")} theme="secondary" classes="hero-video">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-4 h-auto" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM6.79 5.093A.5.5 0 0 0 6 5.5v5a.5.5 0 0 0 .79.407l3.5-2.5a.5.5 0 0 0 0-.814l-3.5-2.5z"></path>
                        </svg>
                    </Button>
                </div>
            </div>
        </Container>

        <!-- red gradient -->
        <div class="bg-gradient-to-tl from-red-500/60 via-neutral-700/90 to-neutral-900 absolute w-full h-full z-10"></div>

        <!-- bg video -->
        <Image src={hero.src} width={hero.width} height={hero.height} class="absolute object-cover w-full h-full" />
        <!-- <video autoplay muted loop class="absolute object-cover w-full h-full">
            <source src={getPublicPath("/Videos/Homepage/roller_v2.mp4")} type="video/mp4" />
        -->
    </div>

    <!-- featured Carli section -->
    <div class="bg-blue-200 py-28">
        <div class="flex flex-col gap-8 space-y-8">
            <Container classes="space-y-8">
                <div class="flex flex-col lg:flex-row items-start justify-between gap-24">
                    <Image src={carli.logo} alt="Carli Logo" width={287} height={116} />

                    <div class="flex flex-col gap-4">
                        <h2 class="text-blue-900">Texas' Only Carli Stocking Dealer</h2>
                        <p class="text-lg font-light text-blue-800">
                            As <i>the only Carli Suspension Stocking Dealer in Texas</i>, nobody carries more Carli parts or knows the performance suspension options for your vehicle better than THOR
                            Off-Road.
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-4 gap-4">
                    {carli.recent.map((i) => <Image src={i.src} width={500} height={500} class="h-[24rem] w-full rounded-sm object-cover shadow-xl" />)}
                </div>

                <div class="flex justify-between items-center">
                    <div class="flex gap-2">
                        <h4 class="text-blue-900">Recent Carli Builds</h4>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-3 h-auto" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M14 2.5a.5.5 0 0 0-.5-.5h-6a.5.5 0 0 0 0 1h4.793L2.146 13.146a.5.5 0 0 0 .708.708L13 3.707V8.5a.5.5 0 0 0 1 0v-6z"></path>
                        </svg>
                    </div>
                    <Link text="Get a Quote for Your Carli Install" url="#" textSize="text-xl" />
                </div>
            </Container>
        </div>
    </div>

    <!-- Jamey quote -->
    <div class="bg-tan-500 py-40 space-y-60 overflow-hidden">
        <div class="relative">
            <Container classes="flex flex-col lg:flex-row gap-16">
                <Image src={jamey.portrait} height={1000} width={1000} class="w-1/2 object-cover shadow-2xl rounded-sm" />

                <div class="space-y-16 py-12">
                    <div class="space-y-8">
                        <h2 class="h1 text-gray-900">The THOR Difference</h2>
                        <p class="text-2xl font-medium text-gray-600 tracking-wide leading-9">
                            THOR is the premiere truck and off-road vehicle outfitter in Texas with the unique automotive knowledge, technical expertise, and deep customer insights to consistently
                            deliver the truck or adventure vehicle of our customers' dreams. Come experience your own purpose-built vehicle.
                        </p>
                        <p class="text-gray-500 leading-9 text-light text-xl">
                            THOR is passionate about creating purpose-built vehicles for our customers, but we also thrive on building strong personal relationships that are based on competence and
                            trust. We are experts in all things off-road and love to inspire and help our customers to build the truck or adventure vehicle that they have always wanted. We aren't
                            satisfied until we hear our customers say, “Wow, I can't believe that's my truck!”
                        </p>
                    </div>

                    <div class="space-y-4">
                        <Image src={jamey.signature} width={394} height={98} class="w-72" />
                        <p class="font-medium text-gray-400">Owner, THOR Off-Road</p>
                    </div>
                </div>
            </Container>

            <Icon name="tracks/tire-tracks_03" class="absolute bottom-0 right-0 text-tan-700/10 w-[500px]" />
            <Icon name="tracks/tire-tracks_03" class="absolute top-0 left-0 text-tan-700/10 w-[500px] rotate-180" />
        </div>

        <div class="space-y-16">
            <Container classes="flex justify-between items-center">
                <h2 class="text-gray-900">Recent Builds</h2>
                <Link text="See More Builds" url="/builds" />
            </Container>

            <div class="grid grid-cols-4 gap-4" id="gallery">
                {builds.map((i) => <Lightbox src={i} classes="object-cover h-full w-full" />)}
            </div>
        </div>
    </div>
</Layout>

<script>
    import BiggerPicture from "bigger-picture";

    let bp = BiggerPicture({
        target: document.body,
    });

    // open (will be a child of the target element above)
    let imageLinks = document.querySelectorAll("#gallery > a");

    // add click listener to open BiggerPicture
    for (let link of imageLinks) {
        link.addEventListener("click", openGallery);
    }

    // function to open BiggerPicture
    function openGallery(e) {
        e.preventDefault();
        bp.open({
            items: imageLinks,
            el: e.currentTarget,
            scale: 0.8,
        });
    }
</script>
